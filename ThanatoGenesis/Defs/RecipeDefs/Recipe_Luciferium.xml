        <li>
            <filter>
                <thingDefs>
                    <li>Plasteel</li>
                </thingDefs>
            </filter>
            <count>100</count>
        </li>
        <li>
            <filter>
                <thingDefs>
                    <li>ComponentSpacer</li>
                </thingDefs>
            </filter>
            <count>3</count>
        </li>
    </ingredients>

